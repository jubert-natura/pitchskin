{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "brand": {
      "yellow":       { "$value": "#FFC629", "$type": "color", "$description": "Primary CTA · announcement bar" },
      "yellow-deep":  { "$value": "#F2B705", "$type": "color", "$description": "Hover / active CTA" },
      "ink":          { "$value": "#111111", "$type": "color", "$description": "Headlines · body · nav" },
      "ink-soft":     { "$value": "#2A2A2A", "$type": "color", "$description": "Secondary body copy" }
    },
    "surface": {
      "cream":   { "$value": "#FAF6EE", "$type": "color", "$description": "Default page warm wash" },
      "stone":   { "$value": "#E8E6E1", "$type": "color", "$description": "Hero + testimonial block" },
      "butter":  { "$value": "#FCE9AE", "$type": "color", "$description": "'Best Used For' header strip" },
      "peach":   { "$value": "#FCE3B5", "$type": "color", "$description": "'Our Toner Serum' block" },
      "wheat":   { "$value": "#FEEDAF", "$type": "color", "$description": "'Let nature do the work'" },
      "sky":     { "$value": "#CFE0F7", "$type": "color", "$description": "'Why it Works' block" },
      "mint":    { "$value": "#BFE0D9", "$type": "color", "$description": "Product label accent · packaging" },
      "white":   { "$value": "#FFFFFF", "$type": "color", "$description": "Cards · PDP background" }
    },
    "semantic": {
      "success":    { "$value": "#2EA36B", "$type": "color", "$description": "Verified badge · check marks" },
      "error":      { "$value": "#D94F3A", "$type": "color", "$description": "Sale price · urgency" },
      "sale":       { "$value": "#E04F3A", "$type": "color", "$description": "Strikethrough promo red" },
      "badge-blue": { "$value": "#2E8B8B", "$type": "color", "$description": "'Most Popular' / '60 Day'" }
    },
    "neutral": {
      "900": { "$value": "#0E0E0E", "$type": "color" },
      "700": { "$value": "#3D3D3D", "$type": "color" },
      "500": { "$value": "#7A7A7A", "$type": "color" },
      "300": { "$value": "#C9C7C2", "$type": "color" },
      "200": { "$value": "#E5E3DE", "$type": "color" },
      "100": { "$value": "#F2F0EA", "$type": "color" }
    }
  },

  "font": {
    "family": {
      "display": { "$value": "\"Inter\", system-ui, -apple-system, \"Segoe UI\", sans-serif", "$type": "fontFamily" },
      "body":    { "$value": "\"Inter\", system-ui, -apple-system, \"Segoe UI\", sans-serif", "$type": "fontFamily" },
      "serif":   { "$value": "\"Tiempos Headline\", \"GT Sectra\", Georgia, serif", "$type": "fontFamily" }
    },
    "weight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" },
      "black":    { "$value": 800, "$type": "fontWeight" }
    }
  },

  "typography": {
    "h1":             { "$type": "typography", "$value": { "fontFamily": "{font.family.display}", "fontSize": "56px",  "lineHeight": 1.05, "fontWeight": 700, "letterSpacing": "-0.02em" } },
    "h2":             { "$type": "typography", "$value": { "fontFamily": "{font.family.display}", "fontSize": "40px",  "lineHeight": 1.1,  "fontWeight": 700, "letterSpacing": "-0.015em" } },
    "h3":             { "$type": "typography", "$value": { "fontFamily": "{font.family.display}", "fontSize": "28px",  "lineHeight": 1.2,  "fontWeight": 700, "letterSpacing": "-0.01em" } },
    "h4":             { "$type": "typography", "$value": { "fontFamily": "{font.family.display}", "fontSize": "20px",  "lineHeight": 1.3,  "fontWeight": 600, "letterSpacing": "-0.005em" } },
    "body-lg":        { "$type": "typography", "$value": { "fontFamily": "{font.family.body}",    "fontSize": "18px",  "lineHeight": 1.5,  "fontWeight": 400, "letterSpacing": "0" } },
    "body":           { "$type": "typography", "$value": { "fontFamily": "{font.family.body}",    "fontSize": "16px",  "lineHeight": 1.55, "fontWeight": 400, "letterSpacing": "0" } },
    "body-sm":        { "$type": "typography", "$value": { "fontFamily": "{font.family.body}",    "fontSize": "14px",  "lineHeight": 1.55, "fontWeight": 400, "letterSpacing": "0" } },
    "caption":        { "$type": "typography", "$value": { "fontFamily": "{font.family.body}",    "fontSize": "12px",  "lineHeight": 1.4,  "fontWeight": 500, "letterSpacing": "0.02em" } },
    "button":         { "$type": "typography", "$value": { "fontFamily": "{font.family.body}",    "fontSize": "14px",  "lineHeight": 1.0,  "fontWeight": 700, "letterSpacing": "0.08em", "textCase": "uppercase" } },
    "eyebrow-italic": { "$type": "typography", "$value": { "fontFamily": "{font.family.serif}",   "fontSize": "16px",  "lineHeight": 1.4,  "fontWeight": 400, "letterSpacing": "0", "fontStyle": "italic" } }
  },

  "space": {
    "0": { "$value": "0px",  "$type": "dimension" },
    "1": { "$value": "4px",  "$type": "dimension" },
    "2": { "$value": "8px",  "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "5": { "$value": "24px", "$type": "dimension" },
    "6": { "$value": "32px", "$type": "dimension" },
    "7": { "$value": "48px", "$type": "dimension" },
    "8": { "$value": "64px", "$type": "dimension" },
    "9": { "$value": "96px", "$type": "dimension" }
  },

  "radius": {
    "none": { "$value": "0px",    "$type": "dimension" },
    "sm":   { "$value": "4px",    "$type": "dimension" },
    "md":   { "$value": "8px",    "$type": "dimension" },
    "lg":   { "$value": "12px",   "$type": "dimension" },
    "xl":   { "$value": "20px",   "$type": "dimension" },
    "pill": { "$value": "9999px", "$type": "dimension" }
  },

  "shadow": {
    "card":  { "$type": "shadow", "$value": [
      { "offsetX": "0px", "offsetY": "1px", "blur": "2px",  "spread": "0px", "color": "rgba(0,0,0,0.04)" },
      { "offsetX": "0px", "offsetY": "4px", "blur": "12px", "spread": "0px", "color": "rgba(0,0,0,0.06)" }
    ]},
    "modal": { "$type": "shadow", "$value": [
      { "offsetX": "0px", "offsetY": "10px", "blur": "40px", "spread": "0px", "color": "rgba(0,0,0,0.12)" }
    ]},
    "focus": { "$type": "shadow", "$value": [
      { "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "3px", "color": "rgba(255,198,41,0.45)" }
    ]}
  },

  "grid": {
    "container":  { "$value": "1280px", "$type": "dimension" },
    "columns":    { "$value": 12,        "$type": "number" },
    "gutter":     { "$value": "24px",    "$type": "dimension" },
    "breakpoint": {
      "xs": { "$value": "360px",  "$type": "dimension" },
      "sm": { "$value": "480px",  "$type": "dimension" },
      "md": { "$value": "768px",  "$type": "dimension" },
      "lg": { "$value": "1024px", "$type": "dimension" },
      "xl": { "$value": "1440px", "$type": "dimension" }
    }
  }
}
